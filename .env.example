# Environment variables for FTP deployment
# Copy this file to .env and fill in your Hostinger FTP details

# Hostinger FTP Credentials
FTP_HOST=your-ftp-host.hostinger.com
FTP_USER=your-ftp-username
FTP_PASSWORD=your-ftp-password
FTP_PORT=21
FTP_REMOTE_ROOT=/public_html

# Example:
# FTP_HOST=ftp.soulthread.in
# FTP_USER=u123456789
# FTP_PASSWORD=YourSecurePassword123
# FTP_PORT=21
# FTP_REMOTE_ROOT=/public_html
